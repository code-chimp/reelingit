root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

[*.{html,css,js,mjs,cjs,json,webmanifest}]
indent_style = space
indent_size = 2

[*.{yml,yaml,toml,md}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
end_of_line = lf
insert_final_newline = true
