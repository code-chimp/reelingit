{
  "name": "reelingit",
  "version": "1.0.0",
  "description": "This is a companion repository for the [Build a Fullstack App in Vanilla JS & Go](https://frontendmasters.com/courses/vanilla-js-go/) course on Frontend Masters. [![Frontend Masters](https://static.frontendmasters.com/assets/brand/logos/full.png)](https://frontendmasters.com/courses/vanilla-js-go/)",
  "main": "index.js",
  "scripts": {
    "build:app": "vite build",
    "manifest:gen": "cem analyze",
    "fix": "run-p fix:*",
    "lint": "run-p lint:*",
    "lint:format": "prettier --check ./public",
    "fix:format": "prettier --write ./public",
    "lint:styles": "stylelint \"./public/**/*.css\"",
    "fix:styles": "stylelint \"./public/**/*.css\" --fix",
    "lint:js": "eslint \"./public/**/*.js\"",
    "fix:js": "eslint \"./public/**/*.js\" --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "allowScripts": {
    "rs-module-lexer@2.8.0": true
  },
  "customElements": "custom-elements.json",
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "browserslist": "^4.28.6",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "vite": "^8.1.5",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
