    {
      "kind": "javascript-module",
      "path": "public/scripts/screens/HomePage.js",
      "declarations": [
        {
          "kind": "class",
          "description": "Home screen showing this week's top movies and a random selection.\n\nOn connect, the element loads its HTML template, fetches movie data from\nthe API, and renders `movie-item` cards into two horizontal lists. The\nelement is intended to be created programmatically with no HTML attributes.\n\nUse it like this:\n```js\nimport { HomePage } from './screens/HomePage.js';\n\ndocument.querySelector('main').appendChild(new HomePage());\n```",
          "name": "HomePage",
          "members": [
            {
              "kind": "field",
              "name": "#templatePromise",
              "privacy": "private",
              "static": true
            },
            {
              "kind": "method",
              "name": "#loadTemplate",
              "static": true,
              "privacy": "private"
            },
            {
              "kind": "method",
              "name": "#initialize",
              "privacy": "private"
            },
            {
              "kind": "method",
              "name": "#render",
              "privacy": "private"
            },
            {
              "kind": "method",
              "name": "#renderMoviesToList",
              "privacy": "private",
              "parameters": [
                {
                  "name": "movies"
                },
                {
                  "name": "ul"
                }
              ]
            }
          ],
          "superclass": {
            "name": "HTMLElement"
          },
          "tagName": "home-page",
          "customElement": true,
          "summary": "Home screen with top and random movie lists"
        }
      ],
      "exports": [
        {
          "kind": "js",
          "name": "HomePage",
          "declaration": {
            "name": "HomePage",
            "module": "public/scripts/screens/HomePage.js"
          }
        },
        {
          "kind": "custom-element-definition",
          "name": "home-page",
          "declaration": {
            "name": "HomePage",
            "module": "public/scripts/screens/HomePage.js"
          }
        }
      ]
    },
